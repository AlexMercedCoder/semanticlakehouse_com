---
import Layout from '../layouts/Layout.astro';
import Parser from 'rss-parser';
import { books } from '../utils/data';

// Fetch latest 3 blogs
let latestBlogs: { title: string, url: string, date: string }[] = [];
try {
  const parser = new Parser();
  const feed = await parser.parseURL('https://datalakehousehub.com/rss.xml');
  latestBlogs = feed.items
    .filter(item => {
      const url = item.link || '';
      return url.startsWith('https://datalakehousehub.com/blog/') && 
             !url.endsWith('/blog/index/') && 
             !url.endsWith('/blog/index');
    })
    .slice(0, 3)
    .map(item => ({
      title: item.title || 'Untitled',
      url: item.link || '#',
      date: item.pubDate ? new Date(item.pubDate).toLocaleDateString() : 'Recent'
    }));
} catch (e) {
  console.error("Failed to fetch RSS feed", e);
}

// Get main books (O'Reilly / Manning)
const mainBooks = books.slice(0, 2);
---

<Layout 
  title="SemanticLakehouse.com | Data Lakehouses & Agentic Analytics" 
  description="Learn about the Semantic Layer, Data Lakehouses, Query Federation, and how Dremio integrates engine, catalog, and semantic layer into a unified platform."
>
  <section class="hero">
    <div class="container hero-content">
      <h1>The Future of Data is the <span class="highlight">Semantic Lakehouse</span></h1>
      <p class="subtitle">Empowering Agentic Analytics through a unified Engine, Catalog, and Semantic Layer.</p>
      <div class="cta-buttons">
        <a href="#concepts" class="btn">Explore Concepts</a>
        <a href="/knowledge-base" class="btn btn-outline">Knowledge Base</a>
      </div>
    </div>
  </section>

  <section id="concepts" class="container concepts-grid">
    <div class="card">
      <h2>Semantic Layer</h2>
      <p>A unified business representation of data, mapping complex underlying structures into familiar, governed metrics and dimensions. It ensures everyone—and every AI agent—speaks the same data language.</p>
    </div>
    
    <div class="card">
      <h2>Data Lakehouse</h2>
      <p>Combining the flexibility, cost-efficiency, and scale of data lakes with the data management and ACID transactions of data warehouses, typically enabled by formats like Apache Iceberg.</p>
    </div>

    <div class="card">
      <h2>Agentic Analytics</h2>
      <p>The next frontier of AI, where autonomous agents not only answer questions but take actions and build workflows based on the governed context provided by a Semantic Layer.</p>
    </div>

    <div class="card">
      <h2>Query Federation & Data Virtualization</h2>
      <p>Access and query data where it lives without physically moving it. Virtualization provides a single access point across multiple heterogeneous sources.</p>
    </div>
  </section>
  
  <section class="container latest-content">
    <div class="split-section">
      <div class="latest-blogs">
        <h2>Latest from the Hub</h2>
        <div class="blog-list">
          {latestBlogs.map(blog => (
            <a href={blog.url} target="_blank" rel="noopener noreferrer" class="card mini-blog-card">
              <h4>{blog.title}</h4>
              <span class="date">{blog.date}</span>
            </a>
          ))}
        </div>
        <div class="view-all">
          <a href="/blog" class="btn btn-outline">View All Blogs</a>
        </div>
      </div>
      
      <div class="featured-books">
        <h2>Featured Books</h2>
        <div class="books-grid">
          {mainBooks.map(book => (
            <a href={book.amazon_url} target="_blank" rel="noopener noreferrer" class="card mini-book-card">
              <img 
                src={book.cover_image_url} 
                alt={`Cover of ${book.title}`} 
                loading="lazy"
              />
            </a>
          ))}
        </div>
        <div class="view-all">
          <a href="/reading" class="btn btn-outline">View All Books</a>
        </div>
      </div>
    </div>
  </section>

  <section class="dremio-section container">
    <div class="card dremio-card">
      <h2>The Dremio Difference</h2>
      <p>Dremio uniquely integrates the <strong>Engine</strong>, <strong>Catalog</strong>, and <strong>Semantic Layer</strong> into a single, cohesive platform. This unified approach eliminates silos, accelerates time-to-insight, and provides the perfect foundation for modern Lakehouses and Agentic AI workloads.</p>
      <a href="https://www.dremio.com" target="_blank" rel="noopener noreferrer" class="btn">Discover Dremio</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 6rem 0;
    text-align: center;
    background: var(--gradient-cosmic-gradient-a);
    background-color: var(--surface-deep-space-canvas);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  .hero-content {
    max-width: 800px;
    margin: 0 auto;
  }
  .hero h1 {
    font-size: var(--text-display);
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-display);
    margin-bottom: 1.5rem;
    font-family: var(--font-grandslang);
  }
  .highlight {
    color: var(--color-deep-violet);
  }
  .subtitle {
    font-size: var(--text-subheading);
    color: var(--color-cloud-whisper);
    letter-spacing: var(--tracking-subheading);
    margin-bottom: 2.5rem;
  }
  .cta-buttons {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
  }
  .concepts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: -3rem;
    position: relative;
    z-index: 10;
  }
  .latest-content {
    margin-top: 5rem;
  }
  .split-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }
  @media (max-width: 768px) {
    .split-section {
      grid-template-columns: 1fr;
    }
  }
  .latest-blogs h2, .featured-books h2 {
    margin-bottom: 1.5rem;
    text-align: center;
    font-family: var(--font-whyte-inktrap-mono);
    text-transform: uppercase;
    font-size: var(--text-heading-sm);
    letter-spacing: 0.2em;
    color: var(--color-code-ghost);
  }
  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .mini-blog-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    border-radius: var(--radius-cards);
  }
  .mini-blog-card h4 {
    margin: 0;
    font-size: var(--text-body);
    flex: 1;
    color: var(--color-cloud-whisper);
  }
  .date {
    color: var(--color-slate-hint);
    font-size: var(--text-body-sm);
    margin-left: 1rem;
    white-space: nowrap;
  }
  .books-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .mini-book-card {
    padding: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: var(--radius-cards);
    overflow: hidden;
  }
  .mini-book-card img {
    width: 100%;
    max-height: 350px;
    object-fit: contain;
  }
  .view-all {
    text-align: center;
    margin-top: 2rem;
  }
  .dremio-section {
    margin-top: 5rem;
    margin-bottom: 3rem;
  }
  .dremio-card {
    text-align: center;
    background: var(--gradient-cosmic-gradient-b);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  .dremio-card p {
    color: var(--color-cloud-whisper);
    margin-bottom: 2rem;
  }
</style>
