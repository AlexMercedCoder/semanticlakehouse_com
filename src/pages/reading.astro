---
import Layout from '../layouts/Layout.astro';
import { books } from '../utils/data';
---

<Layout 
  title="Reading List | SemanticLakehouse.com" 
  description="A directory of Data and AI books authored by Alex Merced."
>
  <div class="container page-header">
    <h1>Recommended Reading</h1>
    <p>Explore authoritative books on Data and AI by Alex Merced, including publications from O'Reilly and Manning.</p>
  </div>

  <div class="container books-grid">
    {books.filter(b => b.category === 'tech').map(book => (
      <a href={book.amazon_url} target="_blank" rel="noopener noreferrer" class="card book-card">
        <div class="cover-wrapper">
          <img 
            src={book.cover_image_url} 
            alt={`Cover of ${book.title}`} 
            loading="lazy"
          />
        </div>
        <h3>{book.title}</h3>
        <span class="read-more">Learn More &rarr;</span>
      </a>
    ))}
  </div>
</Layout>

<style>
  .page-header {
    text-align: center;
    padding: 4rem 0 2rem;
  }
  .books-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    justify-items: center;
  }
  .book-card {
    width: 100%;
    max-width: 300px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .cover-wrapper {
    width: 100%;
    border-radius: 8px;
    margin-bottom: 1.5rem;
  }
  .cover-wrapper img {
    width: 100%;
    max-height: 400px;
    object-fit: contain;
    border-radius: 8px;
  }
  .book-card h3 {
    font-size: 1.2rem;
    margin-bottom: 1rem;
    flex-grow: 1;
  }
  .read-more {
    color: var(--secondary);
    font-weight: 600;
  }
</style>
